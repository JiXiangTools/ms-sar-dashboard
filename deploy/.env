DOCKER_PLATFORM=linux/amd64
ALG_REC_OFFLINE_IMAGE=dockerhub.seobot.cc/alg/rec-offline:260512_442c0ed

AROF_APP_ENV=prod
AROF_DATA_DIR=/app/data/raw
AROF_STATE_DIR=/app/data/state
AROF_LOG_DIR=/app/logs
AROF_TIMEZONE=Asia/Shanghai
TZ=Asia/Shanghai

AROF_KAFKA_BOOTSTRAP_SERVERS=kafka:19092
AROF_PRODUCT_TOPIC=msdr-product
AROF_BEHAVIOR_TOPIC=msdr-behavior

AROF_REDIS_MODE=single
AROF_REDIS_URL=redis://redis:6379/0
AROF_REDIS_DB=0
AROF_ES_URL=http://elasticsearch:9200

AROF_APPID=100001
AROF_TOP_N=50
AROF_MAX_ITEMS_PER_USER=100
AROF_BATCH_SIZE=500
AROF_FLUSH_INTERVAL_SECONDS=5
AROF_HOT_HOUR_LOOKBACK_HOURS=8
AROF_HOT_TTL_SECONDS=1209600
AROF_ICF_TTL_SECONDS=1209600
AROF_ITEM_RELATE_TTL_SECONDS=1209600
AROF_NEARLINE_TTL_SECONDS=604800
AROF_NEARLINE_DISABLED_TTL_SECONDS=600

AROF_PRODUCT_GROUP_ID=alg-rec-offline-product-data-consumer
AROF_BEHAVIOR_GROUP_ID=alg-rec-offline-user-behavior-consumer
AROF_NEARLINE_GROUP_ID=alg-rec-offline-nearline

HOT_HOUR_INTERVAL_SECONDS=3600
HOT_DAY_INTERVAL_SECONDS=86400
HOT_WEEK_INTERVAL_SECONDS=604800
OFFLINE_CAL_INTERVAL_SECONDS=86400

OFFLINE_DATA_HOST_DIR=./data
OFFLINE_LOG_HOST_DIR=./logs
NO_PROXY=localhost,127.0.0.1,::1,kafka,redis,elasticsearch
no_proxy=localhost,127.0.0.1,::1,kafka,redis,elasticsearch
